{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://healthcare-risk-dashboard.vercel.app/schemas/florida_county_facility_context.schema.json",
  "title": "Florida County Facility Context",
  "type": "object",
  "required": ["generated_at_utc", "source", "counties"],
  "properties": {
    "generated_at_utc": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": ["name", "url", "handler", "notes"],
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "handler": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "counties": {
      "type": "object",
      "minProperties": 67
    }
  }
}
